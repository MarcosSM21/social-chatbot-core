APP_ENV=development
LOG_LEVEL=INFO
LLM_PROVIDER=mock
BOT_NAME=SocialBot
BOT_ENABLED=true
BOT_TONE=friendly
BOT_WELCOME_MESSAGE=Local chat started. Write 'q' to quit.
BOT_GOODBYE_MESSAGE=Goodbye!

GENERATION_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3
OLLAMA_TIMEOUT_SECONDS=120
MAX_HISTORY_TURNS=5
ENABLE_PROVIDER_FALLBACK=false

# Public character / behavior defaults
CHARACTER_FILE=characters/support_concierge.json
INSTAGRAM_BEHAVIOR_PROFILE=neutral
INSTAGRAM_REDIRECT_URL=https://example.com/private

MEMORY_STORAGE_BACKEND=sqlite
SQLITE_DATABASE_PATH=data/social_chatbot.sqlite3
JSON_USER_MEMORY_PATH=data/user_memories.json
CHAT_HISTORY_PATH=data/chat_history.json
EXTERNAL_TRACES_PATH=data/external_traces.json
PROVIDER_RAW_PAYLOADS_PATH=data/provider_raw_payloads.json

INTERNAL_API_KEY=dev-internal-api-key
WEBHOOK_VERIFY_TOKEN=replace-me

INSTAGRAM_API_VERSION=v25.0
INSTAGRAM_IG_USER_ID=replace-me
INSTAGRAM_ACCESS_TOKEN=replace-me
INSTAGRAM_APP_SECRET=replace-me
INSTAGRAM_ALLOWED_USER_IDS=
INSTAGRAM_REPLY_COOLDOWN_SECONDS=1
INSTAGRAM_BUNDLE_WINDOW_SECONDS=10
INSTAGRAM_OUTBOUND_DELAY_MIN_SECONDS=60
INSTAGRAM_OUTBOUND_DELAY_MAX_SECONDS=1800
INSTAGRAM_OUTBOUND_SCHEDULER_POLL_SECONDS=2
INSTAGRAM_MAX_CONCURRENT_GENERATIONS=1
INSTAGRAM_PENDING_OUTBOUND_PATH=data/instagram_pending_outbound.json
INSTAGRAM_AUTO_ADMIT_LIMIT=30
INSTAGRAM_ADMITTED_USERS_PATH=data/instagram_admitted_users.json
INSTAGRAM_TURN_BUDGET_LIMIT=20
INSTAGRAM_BLOCKED_USERS_PATH=data/instagram_blocked_users.json
