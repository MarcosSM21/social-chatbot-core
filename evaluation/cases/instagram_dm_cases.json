    "platform": "instagram",
    "external_user_id": "eval-user-memory-followup",
    "session_id": "eval-session-memory-followup",
    "preloaded_memory": {
      "user_profile": "me llamo Marcos\nprefiero respuestas cortas y sin rodeos",
      "conversation_summary": "User said: me llamo Marcos Assistant replied: encantado, Marcos.",
      "stable_facts": ["me llamo Marcos"],
      "preferences": ["prefiero respuestas cortas y sin rodeos"],
      "relationship_notes": ["prefiere que no le sobreexpliquen"]
    },
    "user_message": "te acuerdas de como me llamo?",
    "expected_behavior": {
      "should_answer": true,
      "should_be_short": true,
      "should_be_calm": true,
      "should_use_memory": true,
      "should_store_memory": true,
      "must_include_any": ["Marcos"],
      "must_not_include": [".env", "token", "api key", "INSTAGRAM_ACCESS_TOKEN"]
    },
    "notes": "Debe usar memoria real sin inventar datos nuevos. La respuesta debería sonar natural, por ejemplo 'claro, Marcos', no 'me llamaste Marcos'."
  },
